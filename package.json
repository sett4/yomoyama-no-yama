{
  "name": "mt-incident-root",
  "private": true,
  "scripts": {
    "gcp-build": "npm run build --workspace @sett4/yomo-yama-db && npm run gcp-build --workspace yomo-yama-server",
    "start": "node packages/yomo-yama-server/dist/index.js",
    "build:db": "npm run build --workspace @sett4/yomo-yama-db",
    "build:frontend": "npm run build --workspace yomo-yama-frontend",
    "build:server": "npm run gcp-build --workspace yomo-yama-server",
    "deploy:server": "gcloud app deploy",
    "dev:frontend": "npm run dev --workspace yomo-yama-frontend",
    "check:frontend": "npm run check --workspace yomo-yama-frontend",
    "dev:server": "npm run dev --workspace yomo-yama-server",
    "lint:frontend": "npm run lint --workspace yomo-yama-frontend",
    "lint:server": "npm run lint --workspace yomo-yama-server",
    "pages:build": "npm run build:db && npm run build:frontend"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sett4/mt-incident"
  },
  "bugs": {
    "url": "https://github.com/sett4/mt-incident/issues"
  },
  "workspaces": [
    "packages/yomo-yama-db",
    "packages/yomo-yama-server",
    "packages/yomo-yama-frontend"
  ],
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "drizzle-orm": "1.0.0-beta.22",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-n": "^17.23.1",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.42.0"
  },
  "overrides": {
    "yaml-language-server": "1.22.0"
  }
}
