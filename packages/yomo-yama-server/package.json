{
  "name": "yomo-yama-server",
  "version": "0.0.0",
  "description": "> TODO: description",
  "author": "FUJITA Setsu <fjt.seth@gmail.com>",
  "homepage": "https://github.com/sett4/yomoyama-no-yama#readme",
  "license": "MIT",
  "main": "lib/yomo-yama-server.js",
  "directories": {
    "lib": "lib",
    "test": "__tests__"
  },
  "files": [
    "lib"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sett4/yomoyama-no-yama.git"
  },
  "scripts": {
    "format": "prettier --write src/**/*.{ts,tsx}",
    "test": "jest ./src --watch",
    "posttest": "npm run lint",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "npm run lint -- --fix",
    "start": "node ./dist/index.js",
    "gcp-build": "tsc -p tsconfig-prod.json",
    "deploy": "gcloud app deploy",
    "watch": "tsc -w -p ./",
    "prefecture-wkt-csv": "ts-node -T ./src/cli/prefecture-wkt-csv.ts",
    "dev": "NODE_ENV=development nodemon --exec ts-node -T ./src/index.ts"
  },
  "bugs": {
    "url": "https://github.com/sett4/yomoyama-no-yama/issues"
  },
  "engines": {
    "node": "22.x"
  },
  "devDependencies": {
    "@types/cls-hooked": "^4.3.3",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.1",
    "@types/jsonstream": "^0.8.31",
    "@types/node": "^22.0.0",
    "@types/url-parse": "^1.4.8",
    "jest": "^29.5.0",
    "nodemon": "^3.1.14",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4"
  },
  "dependencies": {
    "@sett4/yomo-yama-db": "0.0.1",
    "@fast-csv/format": "^4.3.5",
    "@fast-csv/parse": "^4.3.6",
    "@google-cloud/logging-winston": "^6.0.1",
    "@tanishiking/aho-corasick": "0.0.1",
    "axios": "^1.4.0",
    "cheerio": "^1.0.0-rc.12",
    "cls-hooked": "^4.2.2",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "JSONStream": "^1.3.5",
    "moment-timezone": "^0.5.43",
    "openai": "^6.35.0",
    "proj4": "^2.9.0",
    "shallow-equal-object": "^1.1.1",
    "url-parse": "^1.5.10",
    "winston": "^3.8.2"
  },
  "jest": {
    "transform": {
      "^.+\\.ts$": [
        "ts-jest",
        {
          "tsconfig": "tsconfig.json"
        }
      ]
    },
    "testPathIgnorePatterns": [
      "/lib/",
      "/node_modules/"
    ],
    "sandboxInjectedGlobals": [
      "Uint8Array",
      "ArrayBuffer"
    ]
  },
  "nodemonConfig": {
    "env": {
      "NODE_ENV": "development"
    },
    "verbose": true
  }
}
