{%- set jsonLD -%}
    {%- set newestPublishedDate = collections.publishedPosts | getNewestCollectionItemDate -%}
    {%- if not newestPublishedDate -%}
        {%- set newestPublishedDate = collections.incidents | getNewestCollectionItemDate -%}
    {%- endif -%}
    {
        "@context": "https://schema.org",
        "@type": "Article",
        "headline": "{%- if title -%}{{ title }}{%- else -%}{{ site.title }}{%- endif -%}",
        "image": ["{{ ogImage }}"],
        "author": {
            "@type": "Person",
            "name": "{{ author.name }}"
        },
        "mainEntityOfPage": "{{ page.url | alwaysProductionUrl }}",
        {% if newestPublishedDate %}"datePublished": "{{ newestPublishedDate | isoDate }}",{% endif %}
        "description": "{{ pageDescription }}"
    }
{% endset -%}
<script type="application/ld+json">{{ jsonLD | minifyInlineJSON | safe }}</script>
