---
import BaseLayout from './BaseLayout.astro';

const { title, description, canonicalPath } = Astro.props as {
  title?: string;
  description?: string;
  canonicalPath?: string;
};
---

<BaseLayout title={title} description={description} canonicalPath={canonicalPath}>
  <article class="content-flow mx-auto max-w-3xl">
    {title && (
      <header>
        <h1>{title}</h1>
      </header>
    )}
    <slot />
  </article>
</BaseLayout>
