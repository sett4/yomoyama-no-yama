---
import IncidentMeta from '../components/IncidentMeta.astro';
import ScrollUpArrow from '../components/ScrollUpArrow.astro';
import type { Incident } from '../lib/incidents';
import { makeDescription } from '../lib/utils';
import BaseLayout from './BaseLayout.astro';

const { post } = Astro.props as { post: Incident };
---

<BaseLayout title={post.title} description={makeDescription(post.content)} canonicalPath={post.url}>
  <article class="single-article content-flow mx-auto max-w-3xl rounded-md border border-line bg-paper-soft px-4 py-6 shadow-sm sm:px-8 sm:py-8">
    <header class="border-b border-line pb-6">
      <p class="mb-3 font-sans text-sm font-bold uppercase tracking-[0.16em] text-ridge">Mountain incident record</p>
      <h1>{post.title}</h1>
    </header>
    <IncidentMeta post={post} />
    <div class="mt-8">
      <p set:html={post.content || ''}></p>
    </div>
  </article>
  <ScrollUpArrow />
</BaseLayout>
