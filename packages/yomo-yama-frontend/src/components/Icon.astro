---
import arrowUp from './svg/arrow-up.svg?raw';
import clipboard from './svg/share-buttons/clipboard.svg?raw';
import rss from './svg/rss.svg?raw';
import twitter from './svg/share-buttons/twitter.svg?raw';

const icons = {
  'arrow-up': arrowUp,
  clipboard,
  rss,
  twitter,
};

type IconName = keyof typeof icons;
const { name } = Astro.props as { name: IconName };
---

<Fragment set:html={icons[name]} />

