---
import type { Incident } from '../lib/incidents';
import PostExcerpt from './PostExcerpt.astro';

const { posts } = Astro.props as { posts: Incident[] };
---

<div class="post-list">
  <ul class="space-y-4">
    {posts.map((post) => (
      <li>
        <PostExcerpt post={post} />
      </li>
    ))}
  </ul>
</div>
