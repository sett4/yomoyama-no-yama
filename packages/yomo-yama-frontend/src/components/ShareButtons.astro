---
import Icon from './Icon.astro';
import { absoluteUrl } from '../lib/utils';
import { phrases, siteConfig } from '../lib/site';

const { title, path } = Astro.props as { title: string; path: string };
const url = absoluteUrl(path);
---

{siteConfig.shareButtons.length > 0 && (
  <div class="share-buttons flex flex-wrap items-center gap-2">
    <p class="m-0 text-xs font-bold uppercase tracking-[0.12em] text-ink-muted">{phrases.share_this_article}</p>
    <ul class="m-0 flex list-none gap-2 p-0">
      {siteConfig.shareButtons.includes('twitter') && (
        <li class="m-0">
          <a
            target="_blank"
            rel="noopener noreferrer"
            data-tooltip={`${phrases.share_on} Twitter - ${phrases.opens_new_tab}`}
            href={`https://twitter.com/intent/tweet/?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`}
            class="twitter flex h-9 w-9 items-center justify-center rounded-md border border-line bg-paper text-mountain no-underline hover:bg-mountain hover:text-paper"
          >
            <Icon name="twitter" />
          </a>
        </li>
      )}
      {siteConfig.shareButtons.includes('clipboard') && (
        <li class="m-0">
          <div class="clipboard flex h-9 w-9 cursor-pointer items-center justify-center rounded-md border border-line bg-paper text-mountain transition-colors hover:bg-mountain hover:text-paper" data-tooltip={phrases.copy_to_clipboard} tabindex="0">
            <Icon name="clipboard" />
          </div>
        </li>
      )}
    </ul>
  </div>
)}
