---
import Icon from '../components/Icon.astro';
import PageLayout from '../layouts/PageLayout.astro';
import { siteConfig } from '../lib/site';
---

<PageLayout title="Subscribe" description="Follow this blog to get notified whenever new article is published." canonicalPath="/subscribe/">
  <p>Subscribe to <strong>{siteConfig.site.title}</strong> to get updates whenever a new article is published.</p>

  <div class="feed-list">
    <ul>
      <li>
        <a href={siteConfig.feed.incidents.path}>
          <Icon name="rss" />
          <span class="name">Atom Feed</span>
        </a>
      </li>
    </ul>
  </div>
</PageLayout>
