---
import PageLayout from '../layouts/PageLayout.astro';
---

<PageLayout canonicalPath="/">
  <section class="not-prose overflow-hidden rounded-md border border-line bg-paper-soft shadow-sm">
    <img src="/images/incident.jpg" alt="武尊山" class="m-0 h-56 w-full rounded-none border-0 object-cover sm:h-72" />
    <div class="px-4 py-6 sm:px-6">
      <p class="mb-3 font-sans text-sm font-bold uppercase tracking-[0.16em] text-ridge">Field notes and records</p>
      <h1 class="mb-4 mt-0 font-sans text-4xl font-bold leading-tight text-ink">よもやまの山</h1>
      <p class="mb-0 text-lg leading-8 text-ink-muted">山にまつわることをちょっとづつ集めています。</p>
    </div>
  </section>

  <section class="not-prose mt-8 grid gap-4 sm:grid-cols-2">
    <a class="rounded-md border border-mountain/30 bg-mountain px-5 py-5 text-paper no-underline shadow-sm transition-colors hover:bg-ridge hover:text-paper" href="/incident/">
      <span class="block font-sans text-xs font-bold uppercase tracking-[0.16em] text-paper/80">Database</span>
      <span class="mt-2 block font-sans text-2xl font-bold">山岳事故</span>
      <span class="mt-3 block text-sm leading-6 text-paper/90">山岳事故のニュースを日付・出典・タグで追える記録です。</span>
    </a>

    <a class="rounded-md border border-line bg-paper-soft px-5 py-5 text-ink no-underline shadow-sm transition-colors hover:border-mountain/50" href="https://free-ricotta-40a.notion.site/IME-065f11006dc3468a9664154389c08b84" target="_blank" rel="noopener noreferrer">
      <span class="block font-sans text-xs font-bold uppercase tracking-[0.16em] text-ridge">Dictionary</span>
      <span class="mt-2 block font-sans text-2xl font-bold">自然地名</span>
      <span class="mt-3 block text-sm leading-6 text-ink-muted">Microsoft IME, macOS 日本語入力, Google 日本語入力用の自然地名辞書です。</span>
    </a>
  </section>

  <img src="/images/imedic.png" alt="MAP" class="mt-10 rounded-md border border-line bg-paper-soft" />
</PageLayout>
