---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getIncidentMonths } from '../lib/incidents';

const months = await getIncidentMonths();
---

<BaseLayout title="Archive" description="All posts published since the start of of the blog back in 2020." canonicalPath="/archive/">
  <section class="content-flow mx-auto max-w-3xl">
    <h1>Archive</h1>
    <h2 id="chronological-archive">Chronological archive</h2>
    <ul class="archive not-prose mt-4 flex list-none flex-wrap gap-2 p-0">
      {months.map((month) => (
        <li class="m-0"><a class="inline-flex rounded border border-line bg-paper-soft px-3 py-2 font-sans text-sm font-bold no-underline" href={`/incident/${month.yearMonth}.html`}>{month.title}</a></li>
      ))}
    </ul>
  </section>
</BaseLayout>
