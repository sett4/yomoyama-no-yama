---
import { getIncidentTags } from '../../../lib/incidents';

export async function getStaticPaths() {
  const tags = await getIncidentTags();
  return tags.map((tag) => ({
    params: { tag: tag.tag },
    props: { tagName: tag.tag },
  }));
}

const { tagName } = Astro.props as { tagName: string };
const target = `/incident/tags/${tagName}.html`;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url='${target}'`} />
  </head>
  <body>
    you should be redirecting to <a href={target}>{target}</a>
  </body>
</html>

